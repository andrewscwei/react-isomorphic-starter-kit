{
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": [
      "DOM",
      "ESNext",
      "WebWorker"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "outDir": "build",
    "paths": {
      "@/*": ["./src/*"],
      "@lib/debug": ["./lib/debug/index"],
      "@lib/esr": ["./lib/esr/index"],
      "@lib/i18n": ["./lib/i18n/index"],
      "@lib/meta": ["./lib/meta/index"],
      "@lib/ssr": ["./lib/ssr/index"]
    },
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "target": "esnext",
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "exclude": [
    "build",
    "node_modules"
  ],
  "include": [
    "lib",
    "src"
  ]
}
